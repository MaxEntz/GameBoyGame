PROJECT_NAME           = "GameBoyGame"
PROJECT_BRIEF          = "Game Boy project documentation"
PROJECT_NUMBER         = ""
OUTPUT_DIRECTORY       = "docs/doxygen"
CREATE_SUBDIRS         = NO

INPUT                  = src \
						 include \
						 asset/include \
						 README.md
FILE_PATTERNS          = *.c \
						 *.h \
						 *.md
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_PATTERNS       = */.git/* \
						 */build/* \
						 */.vscode/*
EXCLUDE_SYMLINKS       = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_UNDOC_RELATIONS   = NO
HIDE_SCOPE_NAMES       = NO

OPTIMIZE_OUTPUT_FOR_C  = YES
INLINE_SOURCES         = YES
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES

STRIP_FROM_PATH        = .
STRIP_FROM_INC_PATH    = include
INCLUDE_PATH           = include

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

INPUT_ENCODING         = UTF-8
OUTPUT_LANGUAGE        = French

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
TAB_SIZE               = 4

MARKDOWN_SUPPORT       = YES

USE_MDFILE_AS_MAINPAGE = README.md
